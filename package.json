  },
  "dependencies": {
    "@steambrew/api": "latest",
    "@steambrew/client": "^5.5.3",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@steambrew/ttc": "^3.2.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "esbuild": "latest",
    "typescript": "latest"
  }
}
