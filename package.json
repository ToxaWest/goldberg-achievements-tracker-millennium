{
  "name": "goldberg-achievements-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx esbuild src/index.tsx --bundle --outfile=index.js --platform=browser --minify --loader:.js=jsx --loader:.ts=tsx --loader:.tsx=tsx",
